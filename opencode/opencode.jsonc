        "Zotero": {
            "type": "local",
            "command": ["zotero-mcp"],
            "environment": { "ZOTERO_LOCAL": "true" },
        },
        "Burp Suite": {
            "type": "remote",
            "url": "http://127.0.0.1:9876",
            "enabled": false,
        },
        "Excalidraw": {
            "type": "remote",
            "url": "https://excalidraw-mcp-app.vercel.app/mcp",
            "enabled": true,
        },
        "Playwright": {
            "type": "local",
            "command": ["npx", "@playwright/mcp@latest", "--extension"],
            "enabled": false,
        },
        "Binary Ninja MCP": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "binary-ninja-mcp",
                "--host",
                "macbook-air",
                "--port",
                "9009",
            ],
            "enabled": true,
        },
        "Jadx MCP": {
            "type": "local",
            "command": [
                "uv",
                "--directory",
                "/Users/CX330/jadx-mcp-server",
                "run",
                "jadx_mcp_server.py",
            ],
            "enabled": true,
        },
        // "Binary Ninja MCP": {
