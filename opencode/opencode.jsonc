            ],
            "enabled": true,
        },
        "Hexstrike": {
            "type": "local",
            "command": [
                "python3",
                "/Users/CX330/hexstrike_mcp.py",
                "--server",
                "http://kali:8888",
            ],
            "enabled": false,
        },
        "Browser MCP": {
            "type": "local",
            "command": ["npx", "@browsermcp/mcp@latest"],
            "enabled": false,
        },
    },
    "provider": {
        "google": {
            "options": {
