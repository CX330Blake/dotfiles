{
    "plugin": [
        "oh-my-opencode",
        "opencode-antigravity-auth@1.6.0",
        "opencode-openai-codex-auth",
    ],
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "Playwright": {
            "type": "local",
            "command": ["npx", "@playwright/mcp@latest", "--extension"],
            "enabled": true,
        },
        "Binary Ninja MCP": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "binary-ninja-mcp",
                "--host",
                "macbook-air",
                "--port",
                "9009",
            ],
            "enabled": true,
        },
        "Jadx MCP": {
            "type": "local",
            "command": [
                "uv",
                "--directory",
                "/Users/CX330/jadx-mcp-server",
                "run",
                "jadx_mcp_server.py",
            ],
            "enabled": true,
        },
        // "Binary Ninja MCP": {
        //     "type": "local",
        //     "command": [
        //         "/Users/CX330/Library/Application Support/Binary Ninja/plugins/binary_ninja_mcp/.venv/bin/python3",
        //         "/Users/CX330/Library/Application Support/Binary Ninja/plugins/binary_ninja_mcp/bridge/binja_mcp_bridge.py",
        //     ],
        //     "enabled": true,
        // },
        "Sequential Thinking": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@modelcontextprotocol/server-sequential-thinking",
            ],
            "enabled": true,
        },
        "Hexstrike": {
            "type": "local",
            "command": [
                "python3",
                "/Users/CX330/hexstrike_mcp.py",
                "--server",
                "http://kali:8888",
            ],
            "enabled": false,
        },
        "Browser MCP": {
            "type": "local",
            "command": ["npx", "@browsermcp/mcp@latest"],
            "enabled": false,
        },
    },
    "provider": {
        "google": {
            "options": {
                "headers": {
                    "Referer": "https://destiny-matrix-analyzer-42239.web.app/",
                },
            },
            "name": "Google",
            "models": {
                "gemini-3-pro-high": {
                    "name": "Gemini 3 Pro High (Antigravity)",
                    "thinking": true,
                    "attachment": true,
                    "limit": {
                        "context": 1048576,
                        "output": 65535,
                    },
                    "modalities": {
                        "input": ["text", "image", "pdf"],
                        "output": ["text"],
                    },
                },
                "gemini-3-pro-medium": {
                    "name": "Gemini 3 Pro Medium (Antigravity)",
                    "thinking": true,
                    "attachment": true,
                    "limit": {
                        "context": 1048576,
                        "output": 65535,
                    },
                    "modalities": {
                        "input": ["text", "image", "pdf"],
                        "output": ["text"],
                    },
                },
                "gemini-3-pro-low": {
                    "name": "Gemini 3 Pro Low (Antigravity)",
                    "thinking": true,
                    "attachment": true,
                    "limit": {
                        "context": 1048576,
                        "output": 65535,
                    },
                    "modalities": {
                        "input": ["text", "image", "pdf"],
                        "output": ["text"],
                    },
                },
                "gemini-3-flash": {
                    "name": "Gemini 3 Flash (Antigravity)",
                    "attachment": true,
                    "limit": {
                        "context": 1048576,
                        "output": 65536,
                    },
                    "modalities": {
                        "input": ["text", "image", "pdf"],
                        "output": ["text"],
                    },
                },
                "gemini-3-flash-lite": {
                    "name": "Gemini 3 Flash Lite (Antigravity)",
                    "attachment": true,
                    "limit": {
                        "context": 1048576,
                        "output": 65536,
                    },
                    "modalities": {
                        "input": ["text", "image", "pdf"],
                        "output": ["text"],
                    },
                },
            },
        },
        "openai": {
            "name": "OpenAI",
            "api": "codex",
            "models": {
                "gpt-5.2": {
                    "name": "GPT-5.2",
                },
                "o3": {
                    "name": "o3",
                    "thinking": true,
                },
                "o4-mini": {
                    "name": "o4-mini",
                    "thinking": true,
                },
                "codex-1": {
                    "name": "Codex-1",
                },
            },
        },
    },
}
